# mentis-docs 설정 (첫 실행 시 docs-sync가 사용자에게 확인하고 이 파일에 저장한다)
# 실제 파일 위치: ~/.config/mentis-docs/config.env
# 스킬은 실행 시작 시 이 파일을 source 하고, 파일이 없으면(최초 실행) 기본값을 보여주며 확인 후 저장한다.

# 원본 저장소들이 모여 있는 상위 폴더. 이 아래 각 하위 폴더가 하나의 레포다.
DOCS_REPOS_ROOT="$HOME/work/repos"

# 문서 루트. 레포 X의 문서 = $DOCS_ROOT/X.md (파일) 또는 $DOCS_ROOT/X/ (폴더).
DOCS_ROOT="$HOME/work/repos/docs"

# pull/diff 대상에서 제외할 폴더(쉼표 구분). 문서 저장소 자신과 비-git 항목은 자동 제외되므로 추가 예외만 적는다.
DOCS_SYNC_EXCLUDE="docs,execute_all"

# (선택) 레포명과 문서 경로가 이름으로 매칭되지 않을 때의 수동 매핑. "레포=문서상대경로" 쉼표 구분.
# 예: DOCS_SYNC_MAP="wadiz-frontend=wadiz-frontend/wadiz-frontend.md,kr.wadiz.account=kr.wadiz.account/README.md"
DOCS_SYNC_MAP=""

# (선택) 문서 저장소에 갱신을 커밋할 때 쓸 브랜치 접두사. 비우면 커밋하지 않고 작업트리 변경만 남긴다.
# 예: "docs/sync"
DOCS_SYNC_BRANCH_PREFIX=""
