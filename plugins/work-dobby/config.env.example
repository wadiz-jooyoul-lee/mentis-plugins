# work-dobby 설정 (첫 실행 시 스킬이 사용자에게 확인하고 이 파일에 저장한다)
# 실제 파일 위치: ~/.config/work-dobby/config.env
# 스킬은 실행 시작 시 이 파일을 source 하고, 비어 있는 값만 사용자에게 확인해 채운 뒤 저장한다.

# ── 기본값 제공(첫 실행 시 현재 기본값을 보여주고 변경 의사를 묻는다) ──

# Jira 호스트 (이슈 조회·링크)
JIRA_BASE_URL="https://wadiz.atlassian.net"

# 작업 루트. 기본적으로 이 아래에 두 폴더가 생긴다:
#   $DOBBY_WORKSPACE/subtree/  → 워크트리(작업 폴더): {repo}-{이슈키}
#   $DOBBY_WORKSPACE/meta/     → 메타(.issue-start/.issue-test/.issue-end/.agent-start)
DOBBY_WORKSPACE="$HOME/work/dobby-workspace"

# (선택) 메타 경로를 subtree와 분리해 직접 지정. 설정하면 메타는 여기에 저장한다.
# 미설정 시 $DOBBY_WORKSPACE/meta 를 사용.
# DOBBY_META_PATH="$HOME/work/dobby-meta"

# 워크트리 생성 기본 베이스 브랜치 (특수 베이스는 실행 시 base= 인자로 덮어씀)
DOBBY_DEFAULT_BASE="master"

# 원본 저장소들이 모여 있는 상위 폴더. 소스 루트 = $DOBBY_REPOS_ROOT/{repo}
# (없으면 git rev-parse --show-toplevel 로 판단)
DOBBY_REPOS_ROOT="$HOME/work"

# 테스트 환경 → 접속 호스트 매핑 (issue-test). 맵에 없는 환경은 사용자에게 직접 테스트 요청
DOBBY_ENV_MAP="dev=dev.wadiz.io,rc=rc.wadiz.kr,rc2=rc2.wadiz.kr,rc4=rc4.wadiz.io"

# ── 선택(미설정 가능) ──

# 참고 문서 루트. 설정하면 {DOBBY_DOCS_ROOT}/{repo} 문서를 먼저 읽는다. 없으면 문서 없이 진행.
# DOBBY_DOCS_ROOT="$HOME/work/repos/docs"

# 테스트 계정. 없으면 로그인 필요한 테스트는 생략하고 가용 범위만 진행.
# TEST_LOGIN_ID=""
# TEST_LOGIN_PW=""
